const t=k=>I18N[lang][k]||I18N.en[k]||k;

const matches=[
 {stage:'Round of 16',live:true,clk:"63'",half:'2nd half',fl:'🇫🇷',fa:'🇸🇪',n:'France',na:'Sweden',g:1,ga:0,
  pH:0.748,pD:0.152,pA:0.10,scorers:['Mbappé','Olise','Dembélé','Isak (SWE)']},
 {stage:'Round of 16',live:true,clk:"28'",half:'1st half',fl:'🇲🇽',fa:'🇪🇨',n:'Mexico',na:'Ecuador',g:0,ga:0,
  pH:0.425,pD:0.327,pA:0.248,scorers:['R. Jiménez','H. Lozano','E. Valencia (ECU)','Caicedo (ECU)']},
 {stage:'Round of 16',live:false,clk:'4:00',half:'kickoff',fl:'🇧🇪',fa:'🇸🇳',n:'Belgium',na:'Senegal',g:0,ga:0,
  pH:0.436,pD:0.291,pA:0.273,scorers:['De Bruyne','Lukaku','S. Mané (SEN)','I. Sarr (SEN)']},
 {stage:'Round of 16',live:false,clk:'8:00',half:'kickoff',fl:'🇺🇸',fa:'🇧🇦',n:'USA',na:'Bosnia',g:0,ga:0,
  pH:0.701,pD:0.191,pA:0.108,scorers:['Pulisic','Weah','Balogun','Džeko (BIH)']},
];

const fair=p=>1/p, price=p=>(1/p)*(1-MARGIN);
const money=n=>'$'+(Math.round(n*100)/100).toLocaleString('en-US',{minimumFractionDigits:n%1?2:0,maximumFractionDigits:2});

function mk(m){
  const live=m.live;
  return {
   result:[
    {g:t('result'),tag:live?'live':'',sub:'90 min + stoppage',src:'FIFA',rows:[
      {q:m.n+' '+t('toWin'),p:[['1',m.pH]]},{q:t('draw'),p:[['X',m.pD]]},{q:m.na+' '+t('toWin'),p:[['2',m.pA]]}]},
    {g:'Double chance',sub:'',src:'FIFA',rows:[
      {q:m.n+' / '+t('draw'),p:[['1X',Math.min(.94,m.pH+m.pD)]]},
      {q:m.n+' / '+m.na,p:[['12',Math.min(.94,m.pH+m.pA)]]},
      {q:m.na+' / '+t('draw'),p:[['X2',Math.min(.94,m.pA+m.pD)]]}]},
   ],
   goals:[
    {g:'Total goals',tag:live?'live':'',sub:(live?'scored + remaining · ':'')+'own goals count',src:'FIFA / Opta',rows:[
      {q:'Over 2.5',p:[['Over',live?.40:.52],['Under',live?.60:.48]]},
      {q:'Over 3.5',p:[['Over',live?.20:.30],['Under',live?.80:.70]]},
      {q:'Both teams score',p:[['Yes',live?.44:.55],['No',live?.56:.45]]}]},
    {g:'Next goal',tag:live?'live':'',sub:live?'who finds the next goal':'opens at kickoff',src:'Opta live',live:true,rows:live?[
      {q:'Next goal',p:[[m.n,m.pH*.85],['None',.18],[m.na,m.pA*.9]]}]:[]},
    {g:'Anytime goalscorer',tag:'hr',sub:'scores any time · own goals excluded',src:'Opta',rows:
      m.scorers.map((s,i)=>({q:s,p:[['Yes',[.42,.30,.24,.17][i]||.15]]}))},
   ],
   cards:[
    {g:'Total cards',tag:live?'live':'',sub:'yellow & red count · players on pitch only',src:'Opta',rows:[
      {q:'Over 3.5 cards',p:[['Over',.55],['Under',.45]]},
      {q:'Over 4.5 cards',p:[['Over',.38],['Under',.62]]},
      {q:'A red card shown',p:[['Yes',.17],['No',.83]]}]},
    {g:'Next booking',tag:live?'live':'',sub:live?'which side gets carded next':'opens at kickoff',src:'Opta live',live:true,rows:live?[
      {q:'Next card',p:[[m.n,.46],[m.na,.54]]}]:[]},
    {g:'Card in window',tag:'hr',sub:live?"a card before 73' · by referee clock":'a card before half-time',src:'Opta',rows:[
      {q:live?"Card before 73'":'Card before HT',p:[['Yes',.34],['No',.66]]}]},
   ],
   fouls:[
    {g:'Total fouls',tag:live?'live':'',sub:'whistled fouls, both teams',src:'Opta',rows:[
      {q:'Over 21.5 fouls',p:[['Over',.50],['Under',.50]]},
      {q:'Over 24.5 fouls',p:[['Over',.36],['Under',.64]]}]},
    {g:'Corners',tag:live?'live':'',sub:'taken corners only · re-takes count once',src:'Opta',rows:[
      {q:'Over 9.5 corners',p:[['Over',.49],['Under',.51]]},
      {q:m.n+' most corners',p:[['Yes',m.pH*.8+.1],['No',1-(m.pH*.8+.1)]]}]},
    {g:'Next 10 minutes',tag:'hr',sub:live?'micro-market · re-prices each minute':'opens at kickoff',src:'Opta live',live:true,rows:live?[
      {q:"A goal before 73'",p:[['Yes',.26],['No',.74]]},
      {q:"A corner before 70'",p:[['Yes',.58],['No',.42]]}]:[]},
   ],
  };
}
const TABS=[['result','result'],['goals','goals'],['cards','cards'],['fouls','fouls']];

function renderMscroll(){
  document.getElementById('mscroll').innerHTML=matches.map((m,i)=>`
    <div class="mcard ${i===curMatch?'on':''}" onclick="selMatch(${i})">
      <div class="when">${m.live?'<span class="live-d"></span>LIVE '+m.clk:m.clk+' ET'}</div>
      <div class="vs">${m.fl} ${m.n}<br>${m.fa} ${m.na}</div>
      <div class="sc">${m.live?m.g+' – '+m.ga:'pre-match'}</div>
    </div>`).join('');
}
function renderBoard(){
  const m=matches[curMatch];
  document.getElementById('board').innerHTML=`<div class="row">
    <div class="tm h"><span class="fl">${m.fl}</span><div><div class="nm">${m.n}</div><div class="wp">${t('win')} ${Math.round(m.pH*100)}%</div></div></div>
    <div class="gl">${m.g}</div>
    <div class="ck"><div class="m">${m.live?m.clk:'–'}</div><div class="s">${m.half}</div></div>
    <div class="gl">${m.ga}</div>
    <div class="tm a"><span class="fl">${m.fa}</span><div><div class="nm">${m.na}</div><div class="wp">${t('win')} ${Math.round(m.pA*100)}%</div></div></div>
  </div>`;
}
function renderTabs(){
  document.getElementById('tabs').innerHTML='<div class="wrap" style="display:flex;gap:6px">'+
    TABS.map(([k,l])=>`<button class="tab ${k===curTab?'on':''}" onclick="selTab('${k}')">${t(l)}</button>`).join('')+'</div>';
}
function renderMarkets(){
  const data=mk(matches[curMatch])[curTab];
  document.getElementById('markets').innerHTML=data.map(grp=>{
    const tagH=grp.tag==='live'?'<span class="tag live">● live</span>':grp.tag==='hr'?'<span class="tag hr">high-res</span>':'';
    if(!grp.rows.length) return `<div class="grp"><div class="ghead"><h3>${grp.g}</h3>${tagH}</div><div class="locked">${grp.sub}</div></div>`;
    return `<div class="grp">
      <div class="ghead"><h3>${grp.g}</h3>${tagH}</div>
      <div class="gsub">${grp.sub?grp.sub+' · ':''}<span class="src">${t('settlesvia2')} ${grp.src}</span></div>
      ${grp.rows.map(r=>`<div class="mk"><div class="q">${r.q}</div><div class="picks">${
        r.p.map(([lab,p])=>{
          const id=curMatch+'|'+curTab+'|'+r.q+'|'+lab, on=sel&&sel.id===id;
          return `<button class="pk ${on?'sel':''}" onclick='choose(${JSON.stringify(id)},${JSON.stringify(r.q)},${JSON.stringify(lab)},${p},${JSON.stringify(grp.src)})'>
            <span class="lab">${lab}</span><span class="od">${price(p).toFixed(2)}</span><span class="fr">fair ${fair(p).toFixed(2)}</span></button>`;
        }).join('')}</div></div>`).join('')}
    </div>`;
  }).join('');
}
function selMatch(i){curMatch=i;sel=null;closeSlip();renderMscroll();renderBoard();renderMarkets();}
function selTab(k){curTab=k;renderTabs();renderMarkets();}

function choose(id,q,lab,p,src){sel={id,q,lab,p,src};renderMarkets();openSlip();}
function openSlip(){
  const m=matches[curMatch];
  document.getElementById('slipBody').innerHTML=`
    <div class="sh"><div class="t">${t('betSlip')}</div><button class="x" onclick="closeSlip()">×</button></div>
    <div class="selq"><b>${sel.lab}</b> · ${sel.q}</div>
    <div class="selmeta">${m.fl} ${m.n} v ${m.na} ${m.fa} · ${t('youPay')} ${price(sel.p).toFixed(2)} · ${t('fair')} ${fair(sel.p).toFixed(2)}</div>
    <div class="settle">⚖ <span>${t('settlesVia')} <b>${sel.src}</b>. ${t('settleNote')}</span></div>
    <span class="fl-lab">${t('yourStake')}</span>
    <div class="stake"><span>$</span><input id="stake" type="number" inputmode="decimal" min="1" value="25"></div>
    <div class="quick">${[10,25,50,100].map(v=>`<button onclick="setStake(${v})">$${v}</button>`).join('')}</div>
    <div class="rk-h"><span id="rl">${t('fullPayout')}</span><span id="rr">${t('protect')} <b>0%</b></span></div>
    <input id="risk" type="range" min="0" max="80" step="10" value="0">
    <div class="po">
      <div class="cell win"><div class="k">${t('ifWins')}</div><div class="v" id="pw"></div></div>
      <div class="cell ls"><div class="k">${t('ifLoses')}</div><div class="v" id="pl"></div></div>
    </div>
    <div class="pnote" id="pn"></div>
    <button class="place" id="place" onclick="place()">${t('placeBet')}</button>`;
  document.getElementById('slip').classList.add('up');
  document.getElementById('stake').oninput=calc;
  document.getElementById('risk').oninput=calc;
  calc();
}
function setStake(v){document.getElementById('stake').value=v;calc();}
function closeSlip(){document.getElementById('slip').classList.remove('up');sel=null;renderMarkets();}
function calc(){
  const stake=Math.max(0,+document.getElementById('stake').value||0);
  const protect=+document.getElementById('risk').value/100, p=sel.p;
  const baseProfit=stake*(price(p)-1), refunded=protect*stake, trim=((1-p)*refunded)/p;
  const adj=baseProfit-trim, loss=stake-refunded;
  document.getElementById('pw').textContent='+'+money(adj);
  document.getElementById('pl').textContent='-'+money(loss);
  document.getElementById('rl').textContent=protect>0?t('winCapped'):t('fullPayout');
  document.getElementById('rr').innerHTML=t('protect')+' <b>'+Math.round(protect*100)+'%</b>';
  document.getElementById('pn').textContent=protect>0
    ? `${t('trimNote1')} ${money(trim)} ${t('trimNote2')} ${money(loss)} ${t('trimNote3')} ${money(stake)}${t('trimNote4')}`
    : `${t('marginNote')} ${money(stake*MARGIN)} (2.2%)${t('marginNote2')}`;
  const b=document.getElementById('place');
  b.disabled=stake<=0||stake>bank;
  b.textContent=stake>bank?t('notEnough'):t('placeBet')+' · '+money(stake);
}
function place(){
  const stake=+document.getElementById('stake').value, protect=+document.getElementById('risk').value/100, p=sel.p;
  const refunded=protect*stake, trim=((1-p)*refunded)/p, adj=stake*(price(p)-1)-trim, loss=stake-refunded;
  const won=Math.random()<p;
  bank+=won?adj:-loss;
  document.getElementById('bank').textContent=money(bank);
  toast(won?`✓ ${sel.lab} · ${sel.q}: ${t('won')} ${money(adj)}`:`✗ ${sel.lab} · ${sel.q}: ${t('lost')} ${money(loss)}`,won);
  closeSlip();
}
function toast(msg,won){const t=document.getElementById('toast');t.textContent=msg;t.className='toast show'+(won?'':' lose');setTimeout(()=>t.className='toast'+(won?'':' lose'),3200);}

function applyStatic(){
  const map={t_live:'live',t_balance:'balance',t_tagA:'tagline_a',t_tagB:'tagline_b',t_intro:'intro',
    t_ourMargin:'ourMargin',t_typicalBook:'typicalBook',t_settlesVia:'settlesVia',t_edgeTitle:'edgeTitle',t_edgeBody:'edgeBody'};
  for(const id in map){const el=document.getElementById(id);if(el)el.textContent=t(map[id]);}
}
function renderLangMenu(){
  document.getElementById('langmenu').innerHTML=LANGS.map(([code,name,fl])=>
    `<button class="${code===lang?'on':''}" onclick="setLang('${code}')">${fl} ${name}</button>`).join('');
  const cur=LANGS.find(l=>l[0]===lang);
  document.getElementById('langflag').textContent=cur[2];
  document.getElementById('langcode').textContent=lang.toUpperCase();
}
function toggleLang(){document.getElementById('langmenu').classList.toggle('open');}
function setLang(code){
  lang=code;
  document.documentElement.lang=code;
  document.documentElement.dir=RTL.includes(code)?'rtl':'ltr';
  document.getElementById('langmenu').classList.remove('open');
  renderLangMenu();applyStatic();renderMscroll();renderBoard();renderTabs();renderMarkets();
  if(sel)openSlip();
}
document.addEventListener('click',e=>{
  if(!e.target.closest('.langwrap')) document.getElementById('langmenu').classList.remove('open');
});

renderLangMenu();applyStatic();renderMscroll();renderBoard();renderTabs();renderMarkets();
</script>
</body>
</html>
